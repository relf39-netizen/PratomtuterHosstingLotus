<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <webSocket enabled="false" />
    <handlers>
      <!-- Specifies that the app.js file is a node.js site -->
      <add name="iisnode" path="app.js" verb="*" modules="iisnode" />
    </handlers>
    <rewrite>
      <rules>
        <!-- 1. Rewrite root or index.html requests to dist/index.html directly so IIS serves the compiled client -->
        <rule name="RootPage" stopProcessing="true">
          <match url="^$|^index\.html$" />
          <action type="Rewrite" url="dist/index.html" />
        </rule>

        <!-- 2. Rewrite requests for compiled static assets to the dist folder so IIS can serve them directly -->
        <rule name="StaticContent" stopProcessing="true">
          <match url="^(assets|logo\.svg|manifest\.json|sw\.js)(.*)$" />
          <action type="Rewrite" url="dist/{R:0}" />
        </rule>

        <!-- 3. All other requests (like /api or client routes) are sent to app.js (Express server) -->
        <rule name="DynamicContent">
          <match url=".*" />
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
          </conditions>
          <action type="Rewrite" url="app.js" />
        </rule>
      </rules>
    </rewrite>
    <directoryBrowse enabled="false" />
  </system.webServer>
</configuration>
